# Profile: ElevenLabs voice + Gemini LLM (ElevenLabs ships no chat LLM).
# Requires ELEVENLABS_API_KEY and GOOGLE_API_KEY in .env.
BAHI_STT_PROVIDER=elevenlabs
BAHI_STT_MODEL=scribe_v2
BAHI_TTS_PROVIDER=elevenlabs
BAHI_TTS_MODEL=eleven_flash_v2_5
BAHI_TTS_VOICE=
BAHI_ORCHESTRATOR_PROVIDER=google
BAHI_ORCHESTRATOR_MODEL=gemini-2.5-flash-lite
BAHI_SPECIALIST_PROVIDER=google
BAHI_SPECIALIST_MODEL=gemini-2.5-flash-lite
BAHI_VISION_PROVIDER=fake
BAHI_ROUTING=delegated
BAHI_LANG_HINTS=hi,en
BAHI_CODEMIX=true
BAHI_REPLY_LANGUAGE=hi
