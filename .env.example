# Copy to .env and fill in the keys you have. Profile presets live in envs/.
# Select a full stack:   set -a; source envs/sarvam.env; set +a
# (or export the vars any 12-factor way — that IS the provider swap)

# --- vendor secrets (only the ones your selected providers need) ---
SARVAM_API_KEY=
ELEVENLABS_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# --- capability -> provider (defaults shown; see envs/*.env for full profiles) ---
BAHI_STT_PROVIDER=fake
BAHI_STT_MODEL=
BAHI_TTS_PROVIDER=fake
BAHI_TTS_MODEL=
BAHI_TTS_VOICE=
BAHI_VISION_PROVIDER=fake

# --- per-role LLM (cross-vendor mixing is first-class) ---
BAHI_ORCHESTRATOR_PROVIDER=fake
BAHI_ORCHESTRATOR_MODEL=fake-orchestrator
BAHI_SPECIALIST_PROVIDER=fake
BAHI_SPECIALIST_MODEL=fake-specialist

# --- behavior ---
BAHI_ROUTING=delegated          # delegated | direct
BAHI_LANG_HINTS=hi,en
BAHI_CODEMIX=true
BAHI_REPLY_LANGUAGE=hi

# --- storage (SQLite local default; Postgres in deployment) ---
DATABASE_URL=sqlite:///bahi.db
